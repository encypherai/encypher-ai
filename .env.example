# Example Environment Variables for Encypher Full-Stack Development
# Copy this to .env and fill in your values

# =============================================================================
# DATABASE (used by docker-compose.full-stack.yml)
# =============================================================================
DATABASE_URL="postgresql+asyncpg://encypher:encypher_dev_password@localhost:5432/encypher"
SECRET_KEY="dev_secret_key_change_in_production"

# =============================================================================
# STRIPE CONFIGURATION (Billing Service)
# =============================================================================
# Get API keys from: https://dashboard.stripe.com/apikeys
STRIPE_API_KEY=sk_test_...

# Webhook secrets
# For local dev: Run `stripe listen --forward-to localhost:8007/api/v1/webhooks/stripe`
# and copy the whsec_... it outputs
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create via Stripe Dashboard or run setup_stripe.py)
# Professional tier ($99/mo, $950/yr)
STRIPE_PRICE_PROFESSIONAL_MONTHLY=price_...
STRIPE_PRICE_PROFESSIONAL_ANNUAL=price_...
# Business tier ($499/mo, $4790/yr)
STRIPE_PRICE_BUSINESS_MONTHLY=price_...
STRIPE_PRICE_BUSINESS_ANNUAL=price_...

# =============================================================================
# NEXTAUTH (Dashboard & Marketing Site)
# =============================================================================
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3001

# =============================================================================
# OAUTH PROVIDERS (Optional)
# =============================================================================
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
