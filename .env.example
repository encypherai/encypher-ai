# Example Environment Variables

# For Dashboard Backend
# Ensure your DATABASE_URL uses the asyncpg driver for PostgreSQL
DATABASE_URL="postgresql+asyncpg://YOUR_DB_USER:YOUR_DB_PASSWORD@YOUR_DB_HOST:YOUR_DB_PORT/YOUR_DB_NAME"
SECRET_KEY="yoursecretkeygoeshere" # Change this in your actual .env file

# For other services if needed
