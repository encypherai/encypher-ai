{
  "manifest_version": 3,
  "name": "Encypher Verify",
  "version": "2.0.0",
  "description": "Verify provenance for any text, image, audio, or video on the web. Powered by C2PA -- cryptographic proof of origin, free for all.",
  "permissions": [
    "activeTab",
    "storage",
    "clipboardWrite",
    "contextMenus",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://api.encypher.com/*",
    "https://*.encypher.com/*"
  ],
  "options_page": "options/options.html",
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "externally_connectable": {
    "matches": [
      "https://dashboard.encypher.com/*",
      "https://*.encypher.com/*",
      "http://localhost/*",
      "http://127.0.0.1/*"
    ]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/detector.js", "content/editor-signer.js"],
      "css": ["content/badge.css", "content/editor-signer.css"],
      "run_at": "document_start",
      "all_frames": true,
      "match_origin_as_fallback": true,
      "match_about_blank": true
    }
  ],
  "commands": {
    "dev-reload": {
      "suggested_key": {
        "default": "Alt+Shift+R",
        "mac": "Alt+Shift+R"
      },
      "description": "Reload Encypher extension and active tab (dev only)"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/*", "content/badge.css", "content/editor-signer.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
