{
  "name": "encypher-verify",
  "version": "1.1.0",
  "description": "Chrome extension to verify and sign Encypher and C2PA-compatible content on any webpage",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --test tests/*.test.js",
    "test:e2e": "node --test tests/e2e/*.test.js",
    "test:all": "npm run test && npm run test:e2e",
    "lint": "eslint .",
    "build": "node scripts/build.js",
    "serve:test": "npx http-server tests/fixtures -p 8080 -c-1"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "http-server": "^14.1.1",
    "puppeteer": "^22.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
