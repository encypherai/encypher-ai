{
  "root": true,
  "env": {
    "browser": true,
    "node": true,
    "es2022": true
  },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "globals": {
    "chrome": "readonly",
    "tinymce": "readonly",
    "CKEDITOR": "readonly"
  },
  "ignorePatterns": [
    "node_modules/",
    "store-assets/",
    "dist/"
  ],
  "overrides": [
    {
      "files": ["tests/**/*.js"],
      "env": {
        "node": true,
        "browser": true
      }
    }
  ],
  "rules": {
    "no-unused-vars": [
      "warn",
      {
        "argsIgnorePattern": "^_",
        "varsIgnorePattern": "^_"
      }
    ]
  }
}
