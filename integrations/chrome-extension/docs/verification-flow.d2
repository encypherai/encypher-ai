direction: right

page: "Web Page"
detector: "Content Script Detector"
badges: "Inline Badges"
worker: "Service Worker"
cache: "Local Cache"
verify_api: "Verify API"
state: "Verified / Pending / Invalid / Revoked"

page -> detector: "scan text + mutations"
detector -> badges: "inject pending state"
detector -> worker: "verify request"
worker -> cache: "cache lookup"
worker -> verify_api: "POST /api/v1/verify"
verify_api -> worker: "verification result"
worker -> badges: "update UI state"
badges -> state: "reader feedback"
