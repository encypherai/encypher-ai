<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
           xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides"
           xsi:type="MailApp">
  <Id>4d7a4c47-7b0f-4ce8-99e1-fdb5eb2c0938</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Encypher AI</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Encypher C2PA Email Provenance"/>
  <Description DefaultValue="Embed and verify cryptographic proof of origin for Outlook email content using C2PA-aligned provenance infrastructure."/>
  <IconUrl DefaultValue="https://encypher.com/assets/logo.png"/>
  <HighResolutionIconUrl DefaultValue="https://encypher.com/assets/logo.png"/>
  <SupportUrl DefaultValue="https://docs.encypher.com"/>

  <AppDomains>
    <AppDomain>https://api.encypher.com</AppDomain>
    <AppDomain>https://dashboard.encypher.com</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.8"/>
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://localhost:4001/taskpane/taskpane.html"/>
        <RequestedHeight>450</RequestedHeight>
      </DesktopSettings>
    </Form>
    <Form xsi:type="ItemEdit">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://localhost:4001/taskpane/taskpane.html"/>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteItem</Permissions>
  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read"/>
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit"/>
  </Rule>

  <DisableEntityHighlighting>false</DisableEntityHighlighting>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides"
                    xsi:type="VersionOverridesV1_0">
    <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides/1.1"
                      xsi:type="VersionOverridesV1_1">
      <Requirements>
        <bt:Sets DefaultMinVersion="1.8">
          <bt:Set Name="Mailbox"/>
        </bt:Sets>
      </Requirements>
      <Hosts>
        <Host xsi:type="MailHost">
          <DesktopFormFactor>
            <FunctionFile resid="Taskpane.Url"/>
            <ExtensionPoint xsi:type="MessageComposeCommandSurface">
              <OfficeTab id="TabDefault">
                <Group id="Encypher.ComposeGroup">
                  <Label resid="GroupLabel"/>
                  <Control xsi:type="Button" id="Encypher.ComposeOpenTaskPane">
                    <Label resid="OpenTaskPaneLabel"/>
                    <Supertip>
                      <Title resid="OpenTaskPaneLabel"/>
                      <Description resid="OpenTaskPaneTooltip"/>
                    </Supertip>
                    <Icon>
                      <bt:Image size="16" resid="Icon.16"/>
                      <bt:Image size="32" resid="Icon.32"/>
                      <bt:Image size="80" resid="Icon.80"/>
                    </Icon>
                    <Action xsi:type="ShowTaskpane">
                      <SourceLocation resid="Taskpane.Url"/>
                    </Action>
                  </Control>
                </Group>
              </OfficeTab>
            </ExtensionPoint>

            <ExtensionPoint xsi:type="MessageReadCommandSurface">
              <OfficeTab id="TabDefault">
                <Group id="Encypher.ReadGroup">
                  <Label resid="GroupLabel"/>
                  <Control xsi:type="Button" id="Encypher.ReadOpenTaskPane">
                    <Label resid="OpenTaskPaneLabel"/>
                    <Supertip>
                      <Title resid="OpenTaskPaneLabel"/>
                      <Description resid="OpenTaskPaneTooltip"/>
                    </Supertip>
                    <Icon>
                      <bt:Image size="16" resid="Icon.16"/>
                      <bt:Image size="32" resid="Icon.32"/>
                      <bt:Image size="80" resid="Icon.80"/>
                    </Icon>
                    <Action xsi:type="ShowTaskpane">
                      <SourceLocation resid="Taskpane.Url"/>
                    </Action>
                  </Control>
                </Group>
              </OfficeTab>
            </ExtensionPoint>
          </DesktopFormFactor>
        </Host>
      </Hosts>

      <Resources>
        <bt:Images>
          <bt:Image id="Icon.16" DefaultValue="https://encypher.com/assets/logo.png"/>
          <bt:Image id="Icon.32" DefaultValue="https://encypher.com/assets/logo.png"/>
          <bt:Image id="Icon.80" DefaultValue="https://encypher.com/assets/logo.png"/>
        </bt:Images>
        <bt:Urls>
          <bt:Url id="Taskpane.Url" DefaultValue="https://localhost:4001/taskpane/taskpane.html"/>
        </bt:Urls>
        <bt:ShortStrings>
          <bt:String id="GroupLabel" DefaultValue="Encypher"/>
          <bt:String id="OpenTaskPaneLabel" DefaultValue="Open C2PA Provenance"/>
        </bt:ShortStrings>
        <bt:LongStrings>
          <bt:String id="OpenTaskPaneTooltip" DefaultValue="Open Encypher tools for cryptographic proof-of-origin signing and verification."/>
        </bt:LongStrings>
      </Resources>
    </VersionOverrides>
  </VersionOverrides>
</OfficeApp>
