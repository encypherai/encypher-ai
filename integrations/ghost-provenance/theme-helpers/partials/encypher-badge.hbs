{{!--
  Encypher Provenance Verification Badge for Ghost Themes

  Include this partial in your post.hbs template to display a C2PA
  verification badge on signed posts.

  Usage in post.hbs:
    {{> encypher-badge}}

  The badge checks for the #encypher-signed internal tag and renders
  a verification link if present.
--}}
{{#has tag="#encypher-signed"}}
<div class="encypher-provenance-badge" style="margin-top: 2rem; padding: 1rem; background: #f0fdf4; border: 1px solid #86efac; border-radius: 8px; font-family: system-ui, sans-serif;">
  <a href="https://verify.encypher.com" target="_blank" rel="noopener noreferrer" style="display: inline-flex; align-items: center; gap: 8px; color: #166534; text-decoration: none; font-size: 14px;">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
      <path d="M9 12l2 2 4-4"/>
    </svg>
    <span>This content is C2PA verified by Encypher</span>
  </a>
</div>
{{/has}}
