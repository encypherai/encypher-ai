# Ghost CMS connection
GHOST_URL=http://localhost:2368
GHOST_ADMIN_API_KEY=your_ghost_admin_api_key_here
GHOST_API_VERSION=v5.0

# Encypher Enterprise API (routed through Traefik API gateway)
# In Docker: use host.docker.internal to reach the host-running stack
# On host: use localhost
ENCYPHER_API_BASE_URL=http://host.docker.internal:8000/api/v1
ENCYPHER_API_KEY=your_encypher_api_key_here

# Integration service
PORT=3000
LOG_LEVEL=info

# Signing options
AUTO_SIGN_ON_PUBLISH=true
AUTO_SIGN_ON_UPDATE=true
SIGNING_TIER=free
ORGANIZATION_NAME=
SIGNING_MODE=managed
MANIFEST_MODE=micro
SEGMENTATION_LEVEL=sentence

# Webhook secret (optional, for verifying webhook payloads)
WEBHOOK_SECRET=

# Database path (SQLite)
DB_PATH=./data/ghost-provenance.db

# Verification badge
BADGE_ENABLED=true
VERIFY_BASE_URL=https://verify.encypherai.com
