direction: down

gateway: "Traefik API Gateway\n:8000"

auth: "Auth Service\n:8001"
web: "Web Service\n:8002"
key: "Key Service\n:8003"
encoding: "Encoding Service\n:8004"
verification: "Verification Service\n:8005"
analytics: "Analytics Service\n:8006"
billing: "Billing Service\n:8007"
notification: "Notification Service\n:8008"
enterprise: "Enterprise API\n:9000"

core_db: "PostgreSQL Core\n:5432"
content_db: "PostgreSQL Content\n:5433"
redis: "Redis Cache\n:6379"
celery: "Redis Celery\n:6380"

gateway -> auth: "/auth"
gateway -> web: "/web"
gateway -> key: "/keys"
gateway -> encoding: "/sign"
gateway -> verification: "/verify"
gateway -> analytics: "/analytics"
gateway -> billing: "/billing"
gateway -> notification: "/notifications"
gateway -> enterprise: "enterprise endpoints"

auth -> core_db: "users + sessions"
web -> core_db: "forms + requests"
key -> core_db: "keys + orgs"
encoding -> core_db: "sign config"
verification -> core_db: "verification metadata"
analytics -> core_db: "usage summaries"
billing -> core_db: "subscriptions"
notification -> core_db: "delivery records"
enterprise -> core_db: "account context"
enterprise -> content_db: "documents + provenance"
auth -> redis: "sessions"
key -> redis: "rate limiting"
verification -> redis: "cache"
analytics -> celery: "async jobs"
notification -> celery: "delivery jobs"
