# GitLab CI/CD Template for Encypher Content Signing
# Copy this file to .gitlab-ci.yml in your repository root

stages:
  - sign
  - verify

variables:
  PYTHON_VERSION: "3.11"
  CONTENT_DIR: "articles"  # Change to your content directory

sign_content:
  stage: sign
  image: python:${PYTHON_VERSION}
  before_script:
    - curl -LsSf https://astral.sh/uv/install.sh | sh
    - export PATH="$HOME/.cargo/bin:$PATH"
    - uv pip install --system encypher-enterprise
  script:
    - |
      encypher sign-repo ./${CONTENT_DIR} \
        --author "${GITLAB_USER_NAME}" \
        --publisher "${CI_PROJECT_NAMESPACE}" \
        --license "CC-BY-4.0" \
        --incremental \
        --use-git-metadata \
        --use-frontmatter \
        --report signing-report.json \
        --report-format html
    - |
      git config user.name "Encypher Bot"
      git config user.email "bot@encypherai.com"
      git add .
      git diff --quiet && git diff --staged --quiet || git commit -m "Sign content [skip ci]"
      git push https://oauth2:${CI_JOB_TOKEN}@${CI_SERVER_HOST}/${CI_PROJECT_PATH}.git HEAD:${CI_COMMIT_REF_NAME}
  artifacts:
    paths:
      - signing-report.json
    expire_in: 30 days
  only:
    - main
    - master
  variables:
    ENCYPHER_API_KEY: ${ENCYPHER_API_KEY}

verify_content:
  stage: verify
  image: python:${PYTHON_VERSION}
  before_script:
    - curl -LsSf https://astral.sh/uv/install.sh | sh
    - export PATH="$HOME/.cargo/bin:$PATH"
    - uv pip install --system encypher-enterprise
  script:
    - |
      encypher verify-repo . \
        --fail-on-tampered \
        --report verification-report.json \
        --report-format html
  artifacts:
    paths:
      - verification-report.json
    expire_in: 30 days
  only:
    - merge_requests
    - schedules
  variables:
    ENCYPHER_API_KEY: ${ENCYPHER_API_KEY}
