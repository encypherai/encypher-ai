# Service Configuration
SERVICE_NAME=coalition-service
SERVICE_PORT=8009
SERVICE_HOST=0.0.0.0
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/encypher_coalition

# Redis
REDIS_URL=redis://localhost:6379/2
REDIS_PASSWORD=
REDIS_DB=2

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# API Gateway
API_GATEWAY_URL=http://localhost:8000

# Service URLs
AUTH_SERVICE_URL=http://localhost:8001
ENTERPRISE_API_URL=http://localhost:8002

# Coalition Settings
REVENUE_SPLIT_ENCYPHER=30
REVENUE_SPLIT_MEMBERS=70
MIN_PAYOUT_THRESHOLD=10
AUTO_ONBOARD_FREE_TIER=true

# Monitoring
PROMETHEUS_PORT=9009
