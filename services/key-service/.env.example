# Key Service Configuration
# Copy to .env for local development (outside Docker)
# For Docker: these are set in docker-compose.full-stack.yml

# ===========================================
# SERVICE CONFIGURATION
# ===========================================
SERVICE_NAME=key-service
SERVICE_PORT=8003
SERVICE_HOST=0.0.0.0
LOG_LEVEL=INFO
ENVIRONMENT=development

# ===========================================
# DATABASE (Local Docker Dev)
# ===========================================
DATABASE_URL=postgresql://encypher:encypher_dev_password@localhost:5432/encypher_keys

# ===========================================
# REDIS
# ===========================================
REDIS_URL=redis://localhost:6379

# ===========================================
# SERVICE URLS
# ===========================================
AUTH_SERVICE_URL=http://localhost:8001

# ===========================================
# CORS
# ===========================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ===========================================
# KEY GENERATION
# ===========================================
KEY_PREFIX=ency_
KEY_LENGTH=32
