# Key Service Configuration

# Service
SERVICE_NAME=key-service
SERVICE_PORT=8003
SERVICE_HOST=0.0.0.0
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/encypher_keys
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/1
REDIS_PASSWORD=
REDIS_DB=1

# Auth Service
AUTH_SERVICE_URL=http://localhost:8001

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://encypherai.com,https://dashboard.encypherai.com

# API Gateway
API_GATEWAY_URL=http://localhost:8000

# Service Discovery
CONSUL_HOST=localhost
CONSUL_PORT=8500

# Monitoring
PROMETHEUS_PORT=9003

# Key Generation
KEY_PREFIX=ency_
KEY_LENGTH=32
