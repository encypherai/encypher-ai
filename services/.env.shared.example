# ============================================
# ENCYPHER SHARED ENVIRONMENT VARIABLES
# ============================================
# These variables should be set as "Shared Variables" in Railway
# and referenced by multiple services.
#
# In Railway: Project Settings > Variables > Shared Variables
# ============================================

# ============================================
# DATABASES (Two-Database Architecture)
# ============================================
# Core DB: Users, Organizations, API Keys, Billing
DATABASE_URL=postgresql://user:password@postgres-core:5432/encypher_core

# Content DB: Documents, Verification, Analytics, Coalition
CONTENT_DATABASE_URL=postgresql://user:password@postgres-content:5432/encypher_content

# ============================================
# REDIS
# ============================================
REDIS_URL=redis://redis:6379

# ============================================
# AUTHENTICATION & SECURITY
# ============================================
JWT_SECRET_KEY=your-super-secret-jwt-key-min-32-chars
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars

# ============================================
# INTERNAL SERVICE URLS
# ============================================
AUTH_SERVICE_URL=http://auth-service.railway.internal:8001
KEY_SERVICE_URL=http://key-service.railway.internal:8003

# ============================================
# FRONTEND URLS
# ============================================
MARKETING_SITE_URL=https://www.encypherai.com
DASHBOARD_URL=https://dashboard.encypherai.com
API_URL=https://api.encypherai.com

# ============================================
# CORS CONFIGURATION
# ============================================
ALLOWED_ORIGINS=https://encypherai.com,https://www.encypherai.com,https://dashboard.encypherai.com

# ============================================
# ENVIRONMENT
# ============================================
ENVIRONMENT=production
LOG_LEVEL=INFO
