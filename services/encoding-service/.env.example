# Encoding Service Configuration
# Copy to .env for local development (outside Docker)
# For Docker: these are set in docker-compose.full-stack.yml

# ===========================================
# SERVICE CONFIGURATION
# ===========================================
SERVICE_NAME=encoding-service
SERVICE_PORT=8004
SERVICE_HOST=0.0.0.0
LOG_LEVEL=INFO
ENVIRONMENT=development

# ===========================================
# DATABASE (Local Docker Dev)
# ===========================================
DATABASE_URL=postgresql://encypher:encypher_dev_password@localhost:5432/encypher_encoding

# ===========================================
# REDIS
# ===========================================
REDIS_URL=redis://localhost:6379
REDIS_CELERY_URL=redis://localhost:6380

# ===========================================
# SERVICE URLS
# ===========================================
AUTH_SERVICE_URL=http://localhost:8001
KEY_SERVICE_URL=http://localhost:8003

# ===========================================
# CORS
# ===========================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ===========================================
# ENCODING CONFIGURATION
# ===========================================
DEFAULT_ENCODING=unicode
MAX_DOCUMENT_SIZE=10485760
SUPPORTED_FORMATS=text,json,markdown
