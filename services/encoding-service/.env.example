# Encoding Service Configuration

# Service
SERVICE_NAME=encoding-service
SERVICE_PORT=8004
SERVICE_HOST=0.0.0.0
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/encypher_encoding
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/2
REDIS_PASSWORD=
REDIS_DB=2

# Auth Service
AUTH_SERVICE_URL=http://localhost:8001

# Key Service
KEY_SERVICE_URL=http://localhost:8003

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://encypherai.com,https://dashboard.encypherai.com

# API Gateway
API_GATEWAY_URL=http://localhost:8000

# Service Discovery
CONSUL_HOST=localhost
CONSUL_PORT=8500

# Monitoring
PROMETHEUS_PORT=9004

# Encoding Configuration
DEFAULT_ENCODING=unicode
MAX_DOCUMENT_SIZE=10485760
SUPPORTED_FORMATS=text,json,markdown
