# API Gateway Environment
GATEWAY_PORT=8000
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000,https://encypherai.com,https://www.encypherai.com

# Downstream services
AUTH_SERVICE_URL=http://localhost:8001
ANALYTICS_SERVICE_URL=http://localhost:8006
ENTERPRISE_API_URL=http://localhost:9000

# Timeouts (seconds)
PROXY_CONNECT_TIMEOUT=5
PROXY_READ_TIMEOUT=30
PROXY_WRITE_TIMEOUT=30
