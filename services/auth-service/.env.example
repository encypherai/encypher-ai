# Auth Service Configuration
# Copy to .env for local development (outside Docker)
# For Docker: these are set in docker-compose.full-stack.yml

# ===========================================
# SERVICE CONFIGURATION
# ===========================================
SERVICE_NAME=auth-service
SERVICE_PORT=8001
SERVICE_HOST=0.0.0.0
LOG_LEVEL=INFO
ENVIRONMENT=development

# ===========================================
# DATABASE (Local Docker Dev)
# ===========================================
DATABASE_URL=postgresql://encypher:encypher_dev_password@localhost:5432/encypher_auth
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ===========================================
# REDIS
# ===========================================
REDIS_URL=redis://localhost:6379

# ===========================================
# JWT CONFIGURATION
# ===========================================
JWT_SECRET_KEY=dev_jwt_secret_key_change_in_production_min_32_chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===========================================
# OAUTH PROVIDERS (Optional for local dev)
# ===========================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ===========================================
# CORS & URLS
# ===========================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
MARKETING_SITE_URL=http://localhost:3000
DASHBOARD_URL=http://localhost:3001
API_URL=http://localhost:8001

# ===========================================
# EMAIL (Optional for local dev)
# ===========================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_TLS=true
EMAIL_FROM=noreply@encypherai.com
EMAIL_FROM_NAME=EncypherAI
