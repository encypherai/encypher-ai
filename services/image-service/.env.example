# image-service environment variables
PORT=8010
LOG_LEVEL=INFO

# Path to a pre-downloaded TrustMark model directory.
# Leave empty to download from HuggingFace on first use.
TRUSTMARK_MODEL_PATH=

# HMAC secret used when deriving per-image watermark messages.
TRUSTMARK_SECRET=change-me-in-production

# Maximum allowed image size in bytes (default: 10MB)
MAX_IMAGE_SIZE_BYTES=10485760
