# ============================================
# Web Service Environment Variables
# ============================================

# Environment
ENVIRONMENT=development
DEBUG=true

# ============================================
# Database Configuration
# ============================================
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password
POSTGRES_DB=encypher_web

# Or use a full connection string:
# SQLALCHEMY_DATABASE_URI=postgresql+psycopg2://user:pass@host:5432/dbname

# ============================================
# Security
# ============================================
SECRET_KEY=your-secret-key-min-32-characters-long

# ============================================
# CORS Origins (comma-separated)
# ============================================
BACKEND_CORS_ORIGINS=http://localhost:3000,https://encypherai.com,https://www.encypherai.com

# ============================================
# Email Configuration (SMTP)
# ============================================
EMAILS_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_TLS=true
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Email addresses
EMAIL_FROM_EMAIL=noreply@encypherai.com
EMAIL_FROM_NAME=Encypher
# NOTE: Use EMAIL_FROM_NAME (not MAIL_FROM_NAME)
SALES_EMAIL=sales@encypherai.com
DEMO_EMAIL=demo@encypherai.com

# ============================================
# Analytics
# ============================================
ANALYTICS_ENABLED=true
