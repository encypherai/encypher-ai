SERVICE_NAME=billing-service
SERVICE_PORT=8007
SERVICE_HOST=0.0.0.0
LOG_LEVEL=INFO

DATABASE_URL=postgresql://user:password@localhost:5432/encypher_billing
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

REDIS_URL=redis://localhost:6379/5
REDIS_DB=5

AUTH_SERVICE_URL=http://localhost:8001
ANALYTICS_SERVICE_URL=http://localhost:8006

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://encypherai.com,https://dashboard.encypherai.com

# Stripe Configuration
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_API_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (created via setup_stripe_products or Stripe Dashboard)
# Professional tier
STRIPE_PRICE_PROFESSIONAL_MONTHLY=price_...
STRIPE_PRICE_PROFESSIONAL_ANNUAL=price_...
# Business tier
STRIPE_PRICE_BUSINESS_MONTHLY=price_...
STRIPE_PRICE_BUSINESS_ANNUAL=price_...

# Stripe Connect (for publisher payouts)
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_...

API_GATEWAY_URL=http://localhost:8000
CONSUL_HOST=localhost
CONSUL_PORT=8500
PROMETHEUS_PORT=9007
