# Backend Configuration
API_V1_STR=/api/v1
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database Configuration
# DATABASE_URL=sqlite:///./app.db # SQLite example, replaced by PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/appdb_dev

# PostgreSQL specific (optional, if not in DATABASE_URL or for more control)
# POSTGRES_SERVER=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=user
# POSTGRES_PASSWORD=password
# POSTGRES_DB=appdb_dev

# CORS Settings
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Initial Admin User (will be created on startup if not exists)
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=changeme123
