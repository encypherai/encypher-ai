# Encypher Enterprise API Configuration
# Copy this file to .env.local and fill in your values

# API URL - use hosted API or local instance
# Hosted: https://api.encypherai.com
# Local: http://localhost:9000
NEXT_PUBLIC_API_URL=http://localhost:9000

# API Key for authentication (required for embedding operations)
NEXT_PUBLIC_API_KEY=your_api_key_here
