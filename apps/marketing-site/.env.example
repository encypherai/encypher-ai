# ============================================
# Encypher Marketing Site Environment Variables
# ============================================

# ============================================
# SHARED: Backend Service URLs
# ============================================
# Auth service URL (for authentication, user management)
NEXT_PUBLIC_AUTH_SERVICE_URL=http://localhost:8001

# Web service URL (for demo requests, analytics, sales forms)
NEXT_PUBLIC_WEB_SERVICE_URL=http://localhost:8002

# Enterprise API URL (for encode/decode tools, signing, verification)
NEXT_PUBLIC_ENTERPRISE_API_URL=http://localhost:9000

# Server-only Enterprise API configuration (used by Next.js /api/tools/* proxy routes)
ENTERPRISE_API_URL=http://localhost:9000
ENTERPRISE_API_KEY=

# Legacy API URL (used by NextAuth and useApiClient for auth endpoints)
# Points to auth-service base URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:8001

# Deprecated - use NEXT_PUBLIC_API_BASE_URL instead
NEXT_PUBLIC_API_URL=http://localhost:8001/api/v1

# Frontend URLs
NEXT_PUBLIC_MARKETING_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3001

# ============================================
# SHARED: Authentication (from Railway shared vars)
# ============================================
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=dev-nextauth-secret-min-32-characters-long

# Cookie domain (set only for cross-subdomain auth in production)
# Leave empty for local development
# NEXTAUTH_COOKIE_DOMAIN=.encypherai.com

# ============================================
# SERVICE-SPECIFIC: OAuth Providers
# ============================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ============================================
# OPTIONAL: Analytics & Feature Flags
# ============================================
# NEXT_PUBLIC_GA_ID=
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# NEXT_PUBLIC_ENABLE_BETA_FEATURES=false
