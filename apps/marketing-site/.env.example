# Encypher Marketing Site Environment Variables

# API URLs
NEXT_PUBLIC_API_URL=https://api.encypherai.com
NEXT_PUBLIC_WEB_SERVICE_URL=http://localhost:8002  # Docker mapped port
NEXT_PUBLIC_DASHBOARD_URL=https://dashboard.encypherai.com
NEXT_PUBLIC_VERIFY_URL=https://verify.encypherai.com

# Analytics (optional)
# NEXT_PUBLIC_GA_ID=
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Feature Flags (optional)
# NEXT_PUBLIC_ENABLE_BETA_FEATURES=false

# Authentication
NEXTAUTH_URL=https://encypherai.com
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_COOKIE_DOMAIN=.encypherai.com

# OAuth Providers
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
