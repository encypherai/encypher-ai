# TEAM_149: Dev container for dashboard with hot reload
FROM node:20-alpine

# Native build deps for canvas (node-gyp) and other compiled modules
RUN apk add --no-cache python3 make g++ pkgconfig \
    cairo-dev pango-dev libjpeg-turbo-dev giflib-dev pixman-dev

# Run as non-root to avoid bind-mount ownership conflicts with host
RUN addgroup -g 1000 -S appuser || true && \
    adduser -u 1000 -S appuser -G appuser || true
USER 1000

WORKDIR /app

# Install dependencies first (cached layer)
COPY package.json package-lock.json* .npmrc* ./
COPY design-system ./design-system/

RUN npm install

# Source code is bind-mounted at runtime for hot reload
# COPY . . is NOT used — docker-compose mounts the source

EXPOSE 3001

CMD ["sh", "-c", "rm -rf /app/.next && mkdir -p /app/.next && npm run dev"]
