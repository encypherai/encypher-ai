{
  "name": "@encypher/icons",
  "version": "1.0.0",
  "description": "Encypher brand icon library - mark, loader, wordmark, and static assets",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./svg/*": "./svg/generated/*",
    "./png/*": "./png/generated/*",
    "./ico/*": "./ico/generated/*"
  },
  "scripts": {
    "build:icons": "python3 scripts/build-icons.py",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.26",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "icons",
    "react",
    "encypher",
    "brand"
  ],
  "author": "Encypher Corporation",
  "license": "UNLICENSED"
}
