direction: right

editor: "Editor"
review: "Editorial Review"
assertions: "Custom Assertions"
byok: "BYOK / Org Signing Identity"
sign: "POST /api/v1/sign"
publish: "Publish Signed Article"
verify: "Verification + Provenance View"
evidence: "Evidence / Audit Trail"

editor -> review: "prepare draft"
review -> assertions: "reviewed_by, fact_check, source metadata"
assertions -> byok: "bind org identity"
byok -> sign: "enterprise signing request"
sign -> publish: "signed body + document id"
publish -> verify: "public or internal verification"
verify -> evidence: "legal / compliance follow-up"
