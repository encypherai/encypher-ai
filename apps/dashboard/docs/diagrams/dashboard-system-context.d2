direction: right

users: {
  label: "Users"
  marketing: "Marketing Site"
  dashboard_user: "Dashboard User"
  publisher_team: "Publisher Team"
}

dashboard: {
  label: "Dashboard App"
  auth: "NextAuth Session"
  pages: "Dashboard Pages"
  org_context: "Organization Context"
  integrations: "Integrations + Settings"
}

backend: {
  label: "Backend"
  enterprise_api: "Enterprise API"
  services: "Microservice Gateway + Services"
}

state: {
  label: "State"
  browser: "Browser Session + Local State"
  postgres: "Platform Databases"
  redis: "Cache + Rate Limits"
}

users.marketing -> dashboard.auth: "signup / login"
users.dashboard_user -> dashboard.pages: "manage keys, analytics, settings"
users.publisher_team -> dashboard.integrations: "connect workflows"
dashboard.auth -> dashboard.org_context: "load active org + role"
dashboard.pages -> backend.enterprise_api: "proxy API calls"
dashboard.integrations -> backend.enterprise_api: "create keys, claims, webhook config"
backend.enterprise_api -> backend.services: "auth, billing, analytics, keys"
backend.enterprise_api -> state.postgres: "documents + org data"
backend.services -> state.postgres: "core business data"
backend.services -> state.redis: "cache + limits"
dashboard.pages -> state.browser: "session + UI state"
