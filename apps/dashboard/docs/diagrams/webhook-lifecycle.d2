direction: right

event: "Encypher Event"
dispatch: "Webhook Dispatcher"
signature: "Signature Validation"
handler: "Publisher Webhook Handler"
actions: "CMS Updates / Alerts / Automation"
retry: "Retry / Failure Handling"

 event -> dispatch: "document.signed, revoked, quota.warning"
 dispatch -> signature: "POST webhook payload"
 signature -> handler: "trusted event"
 handler -> actions: "update DB, notify team, trigger workflows"
 signature -> retry: "invalid or failed delivery"
 retry -> dispatch: "retry strategy"
