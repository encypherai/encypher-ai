# Encypher Dashboard Environment Variables

# API Configuration
NEXT_PUBLIC_API_URL=https://api.encypherai.com/api/v1
NEXT_PUBLIC_SITE_URL=https://encypherai.com

# Authentication
NEXTAUTH_URL=https://dashboard.encypherai.com
NEXTAUTH_SECRET=your-secret-here

# Cookie domain for cross-subdomain SSO (enables shared auth between apps)
# - Railway staging: .up.railway.app
# - Production: .encypherai.com  
# - Local dev: leave unset (cookies scoped to localhost)
NEXTAUTH_COOKIE_DOMAIN=.encypherai.com

# OAuth Providers
# Google OAuth (Get from: https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth (Get from: https://github.com/settings/developers)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Database (if needed)
# DATABASE_URL=postgresql://user:password@localhost:5432/encypher_dashboard

# Feature Flags
# NEXT_PUBLIC_ENABLE_ANALYTICS=true
# NEXT_PUBLIC_ENABLE_BILLING=true
