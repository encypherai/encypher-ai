# ============================================
# Encypher Dashboard Environment Variables
# ============================================

# ============================================
# SHARED: URLs (from Railway shared vars)
# ============================================
# API Gateway URL (Traefik routes to appropriate microservices)
# In development: localhost:8000 (Traefik)
# In production: api.encypherai.com (Railway)
# Routes:
#   /api/v1/keys/*  -> Key Service
#   /api/v1/auth/*  -> Auth Service
#   /api/v1/sign    -> Enterprise API
#   /api/v1/verify  -> Enterprise API
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Frontend URLs
NEXT_PUBLIC_MARKETING_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3001
# Optional: override Integrations page WordPress plugin download button target
# Default fallback: /downloads/encypher-provenance-1.0.0-beta.zip
# NEXT_PUBLIC_WORDPRESS_PLUGIN_DOWNLOAD_URL=https://downloads.encypherai.com/wordpress/encypher-provenance-1.0.0-beta.zip

# ============================================
# SHARED: Authentication (from Railway shared vars)
# ============================================
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=dev-nextauth-secret-min-32-characters-long

# Cookie domain (set only for cross-subdomain auth in production)
# Leave empty for local development
# NEXTAUTH_COOKIE_DOMAIN=.encypherai.com

# ============================================
# SERVICE-SPECIFIC: OAuth Providers
# ============================================
# Google OAuth (Get from: https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth (Get from: https://github.com/settings/developers)
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ============================================
# Bot Protection: Cloudflare Turnstile
# ============================================
# Test keys (always pass): https://developers.cloudflare.com/turnstile/troubleshooting/testing/
#   Site key (always pass):  1x00000000000000000000AA
#   Secret key (always pass): 1x0000000000000000000000000000000AA
#   Site key (always block): 2x00000000000000000000AB
#   Site key (force interactive): 3x00000000000000000000FF
# Production: Get real keys from Cloudflare Dashboard -> Turnstile -> Add site
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# ============================================
# OPTIONAL: Feature Flags
# ============================================
# NEXT_PUBLIC_ENABLE_ANALYTICS=true
# NEXT_PUBLIC_ENABLE_BILLING=true

# ============================================
# DEVELOPMENT: Server Configuration
# ============================================
# Next.js dev server binds to 0.0.0.0 by default (configured in package.json)
# This allows remote access via Tailscale/SSH without port forwarding
