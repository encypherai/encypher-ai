# Windsurf specific — workflows are committed so all devs benefit from shared prompts
# .windsurf/ itself is tracked; ignore only sensitive/ephemeral content within it
.windsurf/*.key
.windsurf/secrets*
*.key

# AI Agent session artifacts (ephemeral)
.teams/TEAM_*.md
.questions/TEAM_*.md
!.teams/TEAM_*.md
!.questions/TEAM_*.md
.tmp/*

# Legacy archive (never commit)
archive/encypherai-backend-old/

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Keys/Secrets
*.crt
*.key
**/private_key.pem

# Distribution / packaging
.Python
build/
dist/
develop-eggs/
*.egg-info/
.eggs/
# Python lib directories (but not src/lib which is used by Next.js)
/lib/
/lib64/
**/python*/lib/
!**/src/lib/
parts/
sdist/
var/
wheels/
*.egg

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
.pytest_cache/
.hypothesis/

# Translations
*.mo
*.pot

